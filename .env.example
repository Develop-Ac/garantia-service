# ==============================================
# garantia-service - .env.example
# ==============================================

# Runtime
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/garantia

# Integracao com email-service (novo backend de e-mail)
EMAIL_SERVICE_URL=http://localhost:3001
EMAIL_SERVICE_DEFAULT_ACCOUNT_ID=1
EMAIL_SERVICE_TIMEOUT_MS=5000

# Variaveis de apresentacao da timeline de garantia
# (nao sao credenciais SMTP)
EMAIL_FROM_NAME=Equipe de Qualidade AC Acessorios
EMAIL_FROM=qualidade@empresa.com
GARANTIA_TIMELINE_FROM=qualidade@empresa.com
GARANTIA_TIMELINE_TO=qualidade@empresa.com

# MinIO (fluxo principal atual)
MINIO_ENDPOINTS=http://127.0.0.1:9000
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123456
MINIO_BUCKET=garantias
MINIO_PATH_PREFIX=garantias/
MINIO_REGION=us-east-1
MINIO_ALLOW_INSECURE_SSL=false

# S3 compativel (opcional/retrocompativel)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_DEFAULT=
S3_BUCKET_AVARIAS=
S3_TLS_INSECURE=false

# MSSQL / OpenQuery (ERP)
MSSQL_HOST=192.168.1.146
MSSQL_PORT=1433
MSSQL_DB=BI
MSSQL_USER=BI_AC
MSSQL_PASSWORD=
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
MSSQL_REQUEST_TIMEOUT_MS=3600000
MSSQL_CANCEL_TIMEOUT_MS=3600000
MSSQL_CONNECT_TIMEOUT_MS=60000
MSSQL_POOL_MAX=10
MSSQL_POOL_MIN=0
MSSQL_POOL_IDLE_MS=30000
